datasource db {
  provider = "postgresql"
}

generator client {
  provider      = "prisma-client-js"
  output        = "../server/src/generated/prisma-client"
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum TenantStatus {
  trial
  active
  suspended

  @@map("tenant_status")
}

enum UserRole {
  super_admin
  org_admin
  compliance_manager
  leadership
  function_owner
  context_owner
  auditor
  viewer

  @@map("user_role")
}

// Task enums — map to existing PostgreSQL enum types created by Privacy migrations.

enum CoreTaskStatus {
  todo
  in_progress
  waiting
  done
  cancelled

  @@map("task_status")
}

enum CoreTaskPriority {
  low
  medium
  high
  critical

  @@map("task_priority")
}

enum CoreTaskSource {
  manual
  compliance
  breach
  request
  regulatory
  review
  consent
  pi_contexts
  notices
  pbd
  training
  template
  system
  pims

  @@map("task_source")
}

enum CoreTaskRecurrenceFrequency {
  daily
  weekly
  monthly
  quarterly
  annual

  @@map("task_recurrence_frequency")
}

// ─── Models ──────────────────────────────────────────────────────────────────

model CoreTenant {
  id                String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String
  slug              String
  status            TenantStatus @default(trial)
  org_admin_user_id String?      @db.Uuid
  created_at        DateTime     @default(now()) @db.Timestamptz
  updated_at        DateTime     @updatedAt @db.Timestamptz
  archived_at       DateTime?    @db.Timestamptz
  archived_by       String?      @db.Uuid

  users         CoreUser[]
  auditLogs     CoreAuditLog[]
  tasks         CoreTask[]
  notifications CoreNotification[]
  aiUsageLogs       CoreAiUsageLog[]
  searchIndex          CoreSearchIndex[]          @relation("CoreSearchIndexTenant")
  reportRuns           CoreReportRun[]            @relation("CoreReportRunTenant")
  scheduledReports     CoreScheduledReport[]      @relation("CoreScheduledReportTenant")
  apiKeys              CoreApiKey[]               @relation("CoreApiKeyTenant")
  webhookSubscriptions CoreWebhookSubscription[]  @relation("CoreWebhookSubscriptionTenant")
  webhookDeliveries    CoreWebhookDelivery[]      @relation("CoreWebhookDeliveryTenant")
  oauthClients         CoreOAuthClient[]          @relation("CoreOAuthClientTenant")
  oauthTokens          CoreOAuthToken[]           @relation("CoreOAuthTokenTenant")
  licenses             CoreTenantLicense[]        @relation("CoreTenantLicenses")
  supportModeSessions  CoreSupportModeSession[]   @relation("CoreSupportModeSessions")
  feedNotifications    CoreTenantFeedNotification[] @relation("CoreFeedNotificationTenant")

  @@map("core_tenants")
}

model CoreModuleRegistry {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_key String   @db.VarChar(50)
  module_key  String   @db.VarChar(100)
  label       String?  @db.VarChar(200)
  sort_order  Int      @default(0)
  created_at  DateTime @default(now()) @db.Timestamptz
  updated_at  DateTime @updatedAt @db.Timestamptz

  @@unique([product_key, module_key])
  @@index([product_key])
  @@map("core_module_registry")
}

model CoreUser {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id            String?   @db.Uuid
  organisation_id      String?   @db.Uuid
  email                String
  password_hash        String
  first_name           String
  last_name            String
  role                 UserRole
  function_id          String?   @db.Uuid
  location_id          String?   @db.Uuid
  is_active            Boolean   @default(true)
  must_change_password Boolean   @default(false)
  last_login_at        DateTime? @db.Timestamptz
  created_by           String?   @db.Uuid
  created_at           DateTime  @default(now()) @db.Timestamptz
  updated_at           DateTime  @updatedAt @db.Timestamptz
  deleted_at           DateTime? @db.Timestamptz

  tenant           CoreTenant?           @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  auditLogs        CoreAuditLog[]
  headedFunctions  CoreFunction[]        @relation("CoreFunctionHead")
  ownedTasks       CoreTask[]            @relation("CoreTaskOwner")
  createdTasks     CoreTask[]            @relation("CoreTaskCreator")
  watchedTasks     CoreTaskWatcher[]     @relation("CoreTaskWatcher")
  notifications    CoreNotification[]    @relation("CoreNotificationUser")
  aiUsageLogs      CoreAiUsageLog[]

  @@map("core_users")
}

// ─── Model: CoreAuditLog ─────────────────────────────────────────────────────

model CoreAuditLog {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String?   @db.Uuid
  organisation_id String?   @db.Uuid
  user_id         String    @db.Uuid
  action          String
  module          String
  record_id       String?
  record_type     String?
  before_state    Json?
  after_state     Json?
  ip_address      String?
  created_at      DateTime  @default(now()) @db.Timestamptz

  user   CoreUser    @relation(fields: [user_id], references: [id], onDelete: Restrict)
  tenant CoreTenant? @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([tenant_id, created_at(sort: Desc)])
  @@index([user_id])
  @@index([module])
  @@map("core_audit_log")
}

// ─── Model: CoreFile ─────────────────────────────────────────────────────────

model CoreFile {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id     String    @db.Uuid
  module_key    String    @db.VarChar(100)
  original_name String    @db.VarChar(500)
  file_path     String    @db.VarChar(1000)
  mime_type     String    @db.VarChar(200)
  size_bytes    Int
  uploaded_by   String    @db.Uuid
  created_at    DateTime  @default(now()) @db.Timestamptz
  deleted_at    DateTime? @db.Timestamptz

  @@index([tenant_id])
  @@index([module_key])
  @@index([uploaded_by])
  @@map("core_files")
}

// ─── E2.5: Org Context Models ─────────────────────────────────────────────────
// These @@map to existing Privacy tables (no migrations needed for the tables).
// core_org_role_types and core_org_role_assignments were created by E2.5 migration.

model CoreOrgProfile {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id          String    @db.Uuid
  name               String
  website            String?
  address            String?
  contact_email      String?
  contact_phone      String?
  industry_sector    String?
  employee_band      String?
  is_sdf             Boolean   @default(false)
  is_consent_manager Boolean   @default(false)
  created_by         String?   @db.Uuid
  created_at         DateTime  @default(now()) @db.Timestamptz
  updated_at         DateTime  @updatedAt @db.Timestamptz
  deleted_at         DateTime? @db.Timestamptz

  @@index([tenant_id])
  @@map("organisations")
}

model CoreFunction {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String    @db.Uuid
  organisation_id String    @db.Uuid
  name            String
  description     String?
  head_user_id    String?   @db.Uuid
  created_by      String?   @db.Uuid
  created_at      DateTime  @default(now()) @db.Timestamptz
  updated_at      DateTime  @updatedAt @db.Timestamptz
  deleted_at      DateTime? @db.Timestamptz

  head_user CoreUser?  @relation("CoreFunctionHead", fields: [head_user_id], references: [id])
  tasks     CoreTask[]

  @@index([tenant_id])
  @@map("functions")
}

model CoreLocation {
  id                       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id                String   @db.Uuid
  organisation_id          String   @db.Uuid
  name                     String
  country_code             String
  region                   String?
  is_data_subject_location Boolean  @default(false)
  is_processing_location   Boolean  @default(false)
  is_active                Boolean  @default(true)
  created_by               String?  @db.Uuid
  created_at               DateTime @default(now()) @db.Timestamptz
  updated_at               DateTime @updatedAt @db.Timestamptz

  @@index([tenant_id])
  @@map("locations")
}

model CoreEntity {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String    @db.Uuid
  organisation_id String    @db.Uuid
  name            String
  legal_name      String
  country_code    String
  is_primary      Boolean   @default(false)
  created_by      String?   @db.Uuid
  created_at      DateTime  @default(now()) @db.Timestamptz
  updated_at      DateTime  @updatedAt @db.Timestamptz
  deleted_at      DateTime? @db.Timestamptz

  @@index([tenant_id])
  @@map("entities")
}

model CoreOrgStakeholder {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id              String    @db.Uuid
  organisation_id        String    @db.Uuid
  name                   String
  role_title             String
  email                  String?
  phone                  String?
  stakeholder_type       String
  stakeholder_type_other String?
  function_id            String?   @db.Uuid
  function_label         String?
  created_by             String?   @db.Uuid
  created_at             DateTime  @default(now()) @db.Timestamptz
  updated_at             DateTime  @updatedAt @db.Timestamptz
  deleted_at             DateTime? @db.Timestamptz

  @@index([tenant_id])
  @@map("org_stakeholders")
}

model CoreOrgRoleType {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key        String   @unique
  label      String
  created_at DateTime @default(now()) @db.Timestamptz

  assignments CoreOrgRoleAssignment[]

  @@map("core_org_role_types")
}

model CoreOrgRoleAssignment {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id        String    @db.Uuid
  role_type_key    String
  name             String?
  email            String?
  phone            String?
  role_title       String?
  appointment_date DateTime? @db.Date
  notes            String?   @db.Text
  created_by       String?   @db.Uuid
  created_at       DateTime  @default(now()) @db.Timestamptz
  updated_at       DateTime  @updatedAt @db.Timestamptz

  role_type CoreOrgRoleType @relation(fields: [role_type_key], references: [key])

  @@unique([tenant_id, role_type_key])
  @@index([tenant_id])
  @@map("core_org_role_assignments")
}

// ─── E2.6: Task Models ────────────────────────────────────────────────────────
// core_tasks and related tables are created by migration 20260524000002.
// Old Privacy tasks/* tables are retained (strangler bridge).

model CoreTask {
  id            String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id     String                  @db.Uuid
  title         String
  description   String?                 @db.Text
  status        CoreTaskStatus          @default(todo)
  priority      CoreTaskPriority        @default(medium)
  source        CoreTaskSource          @default(manual)
  source_id     String?                 @db.Uuid
  source_module String?
  owner_id      String                  @db.Uuid
  function_id   String?                 @db.Uuid
  due_date      DateTime?               @db.Timestamptz
  completed_at  DateTime?               @db.Timestamptz
  created_by    String?                 @db.Uuid
  created_at    DateTime                @default(now()) @db.Timestamptz
  updated_at    DateTime                @updatedAt @db.Timestamptz
  deleted_at    DateTime?               @db.Timestamptz

  tenant     CoreTenant               @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  owner      CoreUser                 @relation("CoreTaskOwner", fields: [owner_id], references: [id])
  creator    CoreUser?                @relation("CoreTaskCreator", fields: [created_by], references: [id])
  function   CoreFunction?            @relation(fields: [function_id], references: [id])
  sub_tasks  CoreTaskSubTask[]
  watchers   CoreTaskWatcher[]
  recurrence CoreTaskRecurrenceConfig?

  @@index([tenant_id])
  @@index([tenant_id, owner_id])
  @@index([tenant_id, status])
  @@map("core_tasks")
}

model CoreTaskSubTask {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  task_id    String   @db.Uuid
  title      String
  completed  Boolean  @default(false)
  sort_order Int      @default(0)
  created_at DateTime @default(now()) @db.Timestamptz

  task CoreTask @relation(fields: [task_id], references: [id], onDelete: Cascade)

  @@index([task_id])
  @@map("core_task_sub_tasks")
}

model CoreTaskWatcher {
  task_id String @db.Uuid
  user_id String @db.Uuid

  task CoreTask  @relation(fields: [task_id], references: [id], onDelete: Cascade)
  user CoreUser  @relation("CoreTaskWatcher", fields: [user_id], references: [id])

  @@id([task_id, user_id])
  @@map("core_task_watchers")
}

model CoreTaskRecurrenceConfig {
  id              String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  task_id         String                      @unique @db.Uuid
  frequency       CoreTaskRecurrenceFrequency
  next_due        DateTime                    @db.Date
  last_created_at DateTime?                   @db.Timestamptz
  created_at      DateTime                    @default(now()) @db.Timestamptz
  updated_at      DateTime                    @updatedAt @db.Timestamptz

  task CoreTask @relation(fields: [task_id], references: [id], onDelete: Cascade)

  @@map("core_task_recurrence_configs")
}

model CoreTaskTemplate {
  id                    String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id             String           @db.Uuid
  title                 String
  description           String?          @db.Text
  source_tag            CoreTaskSource   @default(manual)
  default_priority      CoreTaskPriority @default(medium)
  default_assignee_role String?
  is_system             Boolean          @default(false)
  created_by            String?          @db.Uuid
  created_at            DateTime         @default(now()) @db.Timestamptz
  updated_at            DateTime         @updatedAt @db.Timestamptz
  deleted_at            DateTime?        @db.Timestamptz

  @@index([tenant_id])
  @@map("core_task_templates")
}

// ─── E2.7: Notification Model ─────────────────────────────────────────────────
// core_notifications is created by E2.7 migration.
// Old Privacy notifications table is retained (strangler bridge — no drops).

model CoreNotification {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String    @db.Uuid
  organisation_id String    @db.Uuid
  user_id         String    @db.Uuid
  event_type      String
  title           String
  body            String
  record_ref      String?
  record_module   String?
  is_read         Boolean   @default(false)
  read_at         DateTime? @db.Timestamptz
  created_at      DateTime  @default(now()) @db.Timestamptz
  deleted_at      DateTime? @db.Timestamptz

  tenant CoreTenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  user   CoreUser   @relation("CoreNotificationUser", fields: [user_id], references: [id])

  @@index([tenant_id])
  @@index([tenant_id, user_id])
  @@index([user_id])
  @@map("core_notifications")
}

// ── E2.8a: Regulation Library ────────────────────────────────────────────────

model CoreRegulation {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                String    @unique
  name                String
  short_name          String?
  jurisdiction        String
  authority           String?
  effective_date      DateTime? @db.Date
  description         String?
  status              String    @default("published")
  terminology         Json?
  legal_basis_options Json?
  country_codes       Json?
  changelog           String?
  is_active           Boolean   @default(false)
  owner_scope         String    @default("GLOBAL")
  tenant_id           String?   @db.Uuid
  created_at          DateTime  @default(now()) @db.Timestamptz
  updated_at          DateTime  @updatedAt @db.Timestamptz

  documents CoreRegulationDocument[]
  toggles   CoreTenantRegulationToggle[]

  @@map("core_regulations")
}

model CorePrivacyPrinciple {
  id          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String @unique
  name        String
  description String
  sort_order  Int

  @@map("core_privacy_principles")
}

model CoreRegulationDocument {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  regulation_id     String    @db.Uuid
  title             String
  doc_type          String
  source_type       String
  file_ref          String?
  external_url      String?
  issuing_authority String?
  version           String?
  effective_date    DateTime? @db.Date
  description       String?
  file_size_bytes   Int?
  page_count        Int?
  is_visible        Boolean   @default(true)
  sort_order        Int       @default(0)
  owner_scope       String    @default("GLOBAL")
  tenant_id         String?   @db.Uuid
  created_by        String    @db.Uuid
  created_at        DateTime  @default(now()) @db.Timestamptz
  updated_at        DateTime  @updatedAt @db.Timestamptz
  deleted_at        DateTime? @db.Timestamptz

  regulation CoreRegulation @relation(fields: [regulation_id], references: [id])

  @@map("core_regulation_documents")
}

model CoreTenantRegulationToggle {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id           String   @db.Uuid
  regulation_id       String   @db.Uuid
  is_enabled          Boolean  @default(false)
  jurisdiction_detail String?
  updated_by          String   @db.Uuid
  updated_at          DateTime @updatedAt @db.Timestamptz

  regulation CoreRegulation @relation(fields: [regulation_id], references: [id])

  @@unique([tenant_id, regulation_id])
  @@map("core_tenant_regulation_toggles")
}

// ─── E2.9: AI Configuration + Usage Logging ──────────────────────────────────

enum CoreAiProvider {
  openai
  anthropic
  azure_openai
  gemini
  local_llm

  @@map("core_ai_provider")
}

model CoreAiTenantConfig {
  id                    String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id             String         @unique @db.Uuid
  provider              CoreAiProvider
  api_key               String         @db.VarChar(2000)
  iv                    String         @db.VarChar(100)
  model                 String         @db.VarChar(200)
  azure_endpoint        String?        @db.VarChar(500)
  azure_deployment_name String?        @db.VarChar(200)
  local_llm_base_url    String?        @db.VarChar(500)
  local_llm_model_name  String?        @db.VarChar(200)
  local_llm_api_key_req Boolean        @default(false)
  spend_cap_usd         Decimal?       @db.Decimal(10, 2)
  is_active             Boolean        @default(true)
  configured_at         DateTime       @default(now()) @db.Timestamptz
  configured_by         String?        @db.Uuid
  created_at            DateTime       @default(now()) @db.Timestamptz
  updated_at            DateTime       @updatedAt @db.Timestamptz

  @@map("core_ai_tenant_config")
}

model CoreAiUsageLog {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id          String?   @db.Uuid
  user_id            String?   @db.Uuid
  scope              String    @default("tenant")
  feature            String
  provider           String
  model              String
  input_tokens       Int?
  output_tokens      Int?
  total_tokens       Int?
  estimated_cost_usd Decimal?  @db.Decimal(10, 6)
  latency_ms         Int?
  status             String    @default("success")
  error_code         String?
  request_id         String?
  created_at         DateTime  @default(now()) @db.Timestamptz

  tenant CoreTenant? @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  user   CoreUser?   @relation(fields: [user_id], references: [id])

  @@index([tenant_id, created_at])
  @@index([scope, created_at])
  @@index([feature, created_at])
  @@map("core_ai_usage_logs")
}

// ─── E2.11: Global Search ────────────────────────────────────────────────────
// core_search_index is created by migration 20260524000004.
// Old Privacy search_index table is retained (strangler bridge — no drops).

model CoreSearchIndex {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id  String    @db.Uuid
  module_key String    @db.VarChar(100)
  record_id  String    @db.Uuid
  title      String    @db.VarChar(500)
  body       String?   @db.Text
  url        String?   @db.VarChar(500)
  tags       String[]
  created_at DateTime  @default(now()) @db.Timestamptz
  updated_at DateTime  @updatedAt @db.Timestamptz
  deleted_at DateTime? @db.Timestamptz

  tenant CoreTenant @relation("CoreSearchIndexTenant", fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, module_key, record_id])
  @@index([tenant_id])
  @@index([module_key])
  @@map("core_search_index")
}

// ─── E2.14: Reporting Engine ─────────────────────────────────────────────────
// core_report_templates created by migration 20260524000006.
// core_report_runs and core_scheduled_reports created by same migration.
// Old Privacy report_runs and report_schedules tables retained (strangler bridge).

model CoreReportTemplate {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_key       String   @db.VarChar(100)
  template_key      String   @db.VarChar(100)
  name              String
  description       String?
  report_type_key   String   @db.VarChar(100)
  supported_formats String[] @default(["pdf", "excel", "csv", "html"])
  default_format    String   @default("pdf") @db.VarChar(20)
  sort_order        Int      @default(0)
  is_active         Boolean  @default(true)
  created_at        DateTime @default(now()) @db.Timestamptz
  updated_at        DateTime @updatedAt @db.Timestamptz

  @@unique([product_key, template_key])
  @@index([product_key])
  @@map("core_report_templates")
}

model CoreReportRun {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id       String    @db.Uuid
  template_key    String?   @db.VarChar(100)
  report_type     String    @db.VarChar(100)
  title           String
  scope           Json      @default("{}") @db.JsonB
  format          String    @db.VarChar(20)
  generated_by    String    @db.Uuid
  generated_at    DateTime  @default(now()) @db.Timestamptz
  file_ref        String?
  file_size_bytes Int?
  shared_with     Json      @default("[]") @db.JsonB
  status          String    @default("ready") @db.VarChar(20)
  deleted_at      DateTime? @db.Timestamptz
  created_at      DateTime  @default(now()) @db.Timestamptz
  updated_at      DateTime  @updatedAt @db.Timestamptz

  tenant CoreTenant @relation("CoreReportRunTenant", fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, report_type])
  @@index([tenant_id, generated_at])
  @@map("core_report_runs")
}

model CoreScheduledReport {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id    String    @db.Uuid
  template_key String?   @db.VarChar(100)
  report_type  String    @db.VarChar(100)
  title        String
  scope        Json      @default("{}") @db.JsonB
  format       String    @db.VarChar(20)
  frequency    String    @db.VarChar(20)
  next_run     DateTime  @db.Date
  last_run_at  DateTime? @db.Timestamptz
  recipients   Json      @default("[]") @db.JsonB
  is_active    Boolean   @default(true)
  created_by   String    @db.Uuid
  created_at   DateTime  @default(now()) @db.Timestamptz
  updated_at   DateTime  @updatedAt @db.Timestamptz
  deleted_at   DateTime? @db.Timestamptz

  tenant CoreTenant @relation("CoreScheduledReportTenant", fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([next_run, is_active])
  @@map("core_scheduled_reports")
}

// ─── E2.15a: API Keys + Webhooks ─────────────────────────────────────────────

model CoreApiKey {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id    String    @db.Uuid
  name         String    @db.VarChar(200)
  key_prefix   String    @db.VarChar(10)
  key_hash     String    @db.VarChar(100)
  scopes       String[]
  last_used_at DateTime? @db.Timestamptz
  expires_at   DateTime? @db.Timestamptz
  revoked_at   DateTime? @db.Timestamptz
  created_at   DateTime  @default(now()) @db.Timestamptz
  updated_at   DateTime  @updatedAt @db.Timestamptz

  tenant CoreTenant @relation("CoreApiKeyTenant", fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([key_prefix])
  @@map("core_api_keys")
}

model CoreWebhookSubscription {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String    @db.Uuid
  product_key String    @db.VarChar(100)
  event_key   String    @db.VarChar(200)
  target_url  String    @db.Text
  secret      String?   @db.VarChar(500)
  is_active   Boolean   @default(true)
  deleted_at  DateTime? @db.Timestamptz
  created_at  DateTime  @default(now()) @db.Timestamptz
  updated_at  DateTime  @updatedAt @db.Timestamptz

  tenant     CoreTenant           @relation("CoreWebhookSubscriptionTenant", fields: [tenant_id], references: [id], onDelete: Cascade)
  deliveries CoreWebhookDelivery[]

  @@index([tenant_id])
  @@index([event_key])
  @@map("core_webhook_subscriptions")
}

model CoreWebhookDelivery {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subscription_id String    @db.Uuid
  tenant_id       String    @db.Uuid
  event_key       String    @db.VarChar(200)
  payload         Json      @default("{}") @db.JsonB
  status          String    @default("pending") @db.VarChar(20)
  attempt_count   Int       @default(0)
  last_attempt_at DateTime? @db.Timestamptz
  next_retry_at   DateTime? @db.Timestamptz
  response_status Int?
  created_at      DateTime  @default(now()) @db.Timestamptz
  updated_at      DateTime  @updatedAt @db.Timestamptz

  subscription CoreWebhookSubscription @relation(fields: [subscription_id], references: [id], onDelete: Cascade)
  tenant       CoreTenant              @relation("CoreWebhookDeliveryTenant", fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([subscription_id])
  @@index([status, next_retry_at])
  @@map("core_webhook_deliveries")
}

// ─── E2.15b: OAuth Clients + Tokens + Integration Audit ─────────────────────

model CoreOAuthClient {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id          String    @db.Uuid
  client_id          String    @unique @db.VarChar(80)
  client_secret_hash String    @db.VarChar(100)
  name               String    @db.VarChar(200)
  scopes             String[]
  grant_types        String[]
  revoked_at         DateTime? @db.Timestamptz
  created_at         DateTime  @default(now()) @db.Timestamptz
  updated_at         DateTime  @updatedAt @db.Timestamptz
  deleted_at         DateTime? @db.Timestamptz

  tenant CoreTenant       @relation("CoreOAuthClientTenant", fields: [tenant_id], references: [id], onDelete: Cascade)
  tokens CoreOAuthToken[]

  @@index([tenant_id])
  @@map("core_oauth_clients")
}

model CoreOAuthToken {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  client_id         String    @db.Uuid
  tenant_id         String    @db.Uuid
  access_token_hash String    @db.VarChar(200)
  scopes            String[]
  expires_at        DateTime  @db.Timestamptz
  revoked_at        DateTime? @db.Timestamptz
  created_at        DateTime  @default(now()) @db.Timestamptz

  client CoreOAuthClient @relation(fields: [client_id], references: [id], onDelete: Cascade)
  tenant CoreTenant      @relation("CoreOAuthTokenTenant", fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([client_id])
  @@index([access_token_hash])
  @@map("core_oauth_tokens")
}

model CoreIntegrationAudit {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id     String   @db.Uuid
  actor_type    String   @db.VarChar(20)
  actor_id      String   @db.VarChar(200)
  action        String   @db.VarChar(200)
  resource_type String?  @db.VarChar(100)
  resource_id   String?  @db.VarChar(200)
  status_code   Int?
  ip_address    String?  @db.VarChar(100)
  created_at    DateTime @default(now()) @db.Timestamptz

  @@index([tenant_id])
  @@index([tenant_id, created_at(sort: Desc)])
  @@index([actor_type])
  @@map("core_integration_audit")
}

// ─── E2.16: Tenant Licenses + Support Mode Sessions ──────────────────────────

enum CoreLicenseTier {
  core
  professional
  enterprise

  @@map("core_license_tier")
}

model CoreTenantLicense {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id   String          @db.Uuid
  product_key String          @db.VarChar(100)
  tier        CoreLicenseTier @default(core)
  valid_from  DateTime        @default(now()) @db.Timestamptz
  valid_until DateTime?       @db.Timestamptz
  assigned_by String          @db.Uuid
  created_at  DateTime        @default(now()) @db.Timestamptz
  updated_at  DateTime        @updatedAt @db.Timestamptz
  deleted_at  DateTime?       @db.Timestamptz

  tenant CoreTenant @relation("CoreTenantLicenses", fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@map("core_tenant_licenses")
}

model CoreSupportModeSession {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id           String    @db.Uuid
  super_admin_user_id String    @db.Uuid
  issued_at           DateTime  @default(now()) @db.Timestamptz
  expires_at          DateTime  @db.Timestamptz
  exited_at           DateTime? @db.Timestamptz
  audit_note          String?   @db.Text
  created_at          DateTime  @default(now()) @db.Timestamptz

  tenant CoreTenant @relation("CoreSupportModeSessions", fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([super_admin_user_id])
  @@map("core_support_mode_sessions")
}

// ─── E2.17: Regulatory Feed Curation ─────────────────────────────────────────
// Platform-level (no tenant_id) feed source registry and ingested items.
// core_tenant_feed_notifications is tenant-scoped.

enum CoreFeedReviewStatus {
  pending
  approved
  rejected
  mapped

  @@map("core_feed_review_status")
}

model CoreFeedSource {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  url             String
  scrape_schedule String?   @db.VarChar(100)
  parse_rules     Json?     @db.JsonB
  is_active       Boolean   @default(true)
  created_at      DateTime  @default(now()) @db.Timestamptz
  updated_at      DateTime  @updatedAt @db.Timestamptz
  deleted_at      DateTime? @db.Timestamptz

  items CoreFeedItem[]

  @@map("core_feed_sources")
}

model CoreFeedItem {
  id              String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  source_id       String?              @db.Uuid
  external_id     String?              @db.VarChar(500)
  title           String
  summary         String?              @db.Text
  url             String?              @db.Text
  published_at    DateTime?            @db.Timestamptz
  raw_payload     Json?                @db.JsonB
  review_status   CoreFeedReviewStatus @default(pending)
  regulation_code String?              @db.VarChar(100)
  reviewed_by     String?              @db.Uuid
  reviewed_at     DateTime?            @db.Timestamptz
  created_at      DateTime             @default(now()) @db.Timestamptz
  updated_at      DateTime             @updatedAt @db.Timestamptz

  source        CoreFeedSource?             @relation(fields: [source_id], references: [id])
  notifications CoreTenantFeedNotification[]

  @@unique([source_id, external_id])
  @@index([review_status])
  @@index([regulation_code])
  @@index([created_at(sort: Desc)])
  @@map("core_feed_items")
}

model CoreTenantFeedNotification {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenant_id         String    @db.Uuid
  feed_item_id      String    @db.Uuid
  notification_type String    @db.VarChar(50)
  notified_at       DateTime  @default(now()) @db.Timestamptz
  read_at           DateTime? @db.Timestamptz

  tenant    CoreTenant   @relation("CoreFeedNotificationTenant", fields: [tenant_id], references: [id], onDelete: Cascade)
  feed_item CoreFeedItem @relation(fields: [feed_item_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([tenant_id, read_at])
  @@index([feed_item_id])
  @@map("core_tenant_feed_notifications")
}
